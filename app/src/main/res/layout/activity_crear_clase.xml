<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CrearClase">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Clase"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp"/>

        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:lottie_rawRes="@raw/wumpussmile"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"/>

        <EditText
            android:id="@+id/etNombreClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre de la clase"
            android:inputType="text"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNrcClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NRC de la clase (5 dígitos)"
            android:inputType="number"
            android:maxLength="5"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etEstudiantesClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número de estudiantes inscritos"
            android:inputType="number"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etHorarioClase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Horario (Ej: Lun-Mie 09:00 AM)"
            android:inputType="text"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelarClase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/rojo_error"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnGuardarClase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Guardar"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/verde_exito"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>